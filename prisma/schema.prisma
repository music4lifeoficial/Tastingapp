generator client {
  previewFeatures = ["driverAdapters"]
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Status {
  ACTIVE
  PAUSED
  TERMINATED
}

enum QuestionType {
  STAR
  TEXT
  OPTION
}

enum QuestionScope {
  GLOBAL
  VARIANT
}

model Flavor {
  id          String    @id @default(cuid())
  name        String    @unique
  sessions    Session[]
}

model Session {
  id          String      @id @default(cuid())
  flavorId    String
  flavor      Flavor      @relation(fields: [flavorId], references: [id])
  customCode  String?     @unique
  status      Status      @default(ACTIVE)
  createdAt   DateTime    @default(now())
  variants    Variant[]
  questions   Question[]
  profiles    Profile[]
  responses   Response[]
}

model Variant {
  id          String     @id @default(cuid())
  sessionId   String
  session     Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  code        String     // e.g. "CL-1"
  responses   Response[]
}

model Question {
  id          String        @id @default(cuid())
  sessionId   String
  session     Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  text        String
  type        QuestionType
  scope       QuestionScope
  options     String?       // Comma separated options if type is OPTION
  order       Int           @default(0)
  responses   Response[]
}

model Profile {
  id          String     @id @default(cuid())
  sessionId   String
  session     Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name        String
  drinksBeer  Boolean
  drinksIpa   Boolean
  responses   Response[]
}

model Response {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  variantId   String?  // null if global question
  variant     Variant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  value       String   // normalized value as string
}